# Halo Swing local environment template.
# Copy to .env for local-only overrides. Do not commit real secrets.

HALO_SWING_ENVIRONMENT=local
HALO_SWING_LOG_LEVEL=INFO
HALO_SWING_DISABLE_DOTENV=

# Persistence gates are not approved yet. Leave blank until MIGRATION_GO and
# REPOSITORY_GO are recorded.
HALO_SWING_DATABASE_URL=
HALO_SWING_BINANCE_TESTNET=true
HALO_SWING_BINANCE_FORCE_TESTNET_EXECUTION=true
HALO_SWING_BINANCE_ENABLE_LIVE_TRADING=false
HALO_SWING_BINANCE_CREDENTIALS_PATH=state/binance_credentials.enc.json
HALO_SWING_BTC_RISK_SETTINGS_PATH=state/btc_risk_settings.json
HALO_SWING_BTC_RISK_STATE_PATH=state/btc_risk_state.json
HALO_SWING_RUNTIME_CHECKPOINT_PATH=state/runtime_checkpoints.jsonl
HALO_SWING_RUNTIME_RETENTION_MAX_RECORDS=1000
HALO_SWING_RUNTIME_RETENTION_MAX_BYTES=5000000
HALO_SWING_RUNTIME_FAILURE_WINDOW=20
HALO_SWING_RUNTIME_FAILURE_THRESHOLD=3
HALO_SWING_HERMES_CONFIG_PATH=
HALO_SWING_TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
HALO_SWING_TELEGRAM_GATEWAY=
HALO_SWING_TELEGRAM_GATEWAY_URL=

# Live data integrations. Leave blank to keep fixture-backed offline defaults.
# Fill one supported key per provider to auto-select its live provider.
HALO_SWING_MARKET_DATA_API_KEY=
POLYGON_API_KEY=
HALO_SWING_MACRO_API_KEY=
HALO_SWING_FRED_API_KEY=
FRED_API_KEY=
HALO_SWING_NEWS_API_KEY=
NEWS_API_KEY=

# Optional explicit live-mode flags for operator intent/source validation.
# API-key auto-select works without these when a matching key above is set.
# HALO_SWING_MARKET_DATA_MODE=live
# HALO_SWING_MACRO_DATA_MODE=live
# HALO_SWING_NEWS_DATA_MODE=live
